GIGACHAT_CREDENTIALS=your_credentials_here
GIGACHAT_VERIFY_SSL=false
GIGACHAT_MODEL=GigaChat

# LM Studio (локальный OpenAI-совместимый сервер)
LMSTUDIO_BASE_URL=http://host.docker.internal:1234/v1
LMSTUDIO_API_KEY=lm-studio
LMSTUDIO_DEFAULT_MODEL=llama-3.2-1b-instruct

# Ollama (удалённый сервер с Basic Auth, альтернативный провайдер playground)
OLLAMA_BASE_URL=https://llm.nikfil.ru
OLLAMA_USERNAME=
OLLAMA_PASSWORD=
OLLAMA_DEFAULT_MODEL=llama3.2:1b
